{
    "name": "jardissupport/auth",
    "description": "Token management, session handling, and security utilities for authentication and authorization",
    "type": "library",
    "license": "proprietary",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "authors": [
        {
            "name": "Headgent Development",
            "email": "jardisDev@headgent.com"
        }
    ],
    "require": {
        "php": ">=8.3",
        "ext-sodium": "*",
        "ext-mbstring": "*",
        "jardissupport/contract": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^2.0.4",
        "squizlabs/php_codesniffer": "^3.11.2 || ^4.0.0"
    },
    "autoload": {
        "psr-4": {
            "JardisSupport\\Auth\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "JardisSupport\\Auth\\Tests\\": "tests/"
        }
    },
    "homepage": "https://github.com/jardisSupport/auth",
    "support": {
        "issues": "https://github.com/jardisSupport/auth/issues",
        "email": "jardisDev@headgent.com"
    },
    "keywords": [
        "auth",
        "authentication",
        "authorization",
        "token",
        "session",
        "security",
        "domain driven design",
        "jardis",
        "Headgent"
    ]
}
